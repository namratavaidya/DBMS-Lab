create a procedure to display the content of the table :: st_info



create or replace procedure show_st
as
 s_roll st_info.roll% type;
 s_name st_info.roll% type;
 s_sub1 st_info.roll% type;
 s_sub2 st_info.roll% type;
 s_sub3 st_info.roll% type;
 s_sub4 st_info.roll% type;
begin
 select roll,name,sub1,sub2,sub3,sub4 into s_roll, s_name,s_sub1,s_sub2,s_sub3,s_sub4 from st_info;
 dbms_output.put_line ('Roll no : ' || s_roll);
 dbms_output.put_line ('Name of the Student : ' || s_name);
 dbms_output.put_line ('Marks of Sub1 : ' || s_sub1);
 dbms_output.put_line ('Marks of Sub2 : ' || s_sub2);
 dbms_output.put_line ('Marks of Sub3 : ' || s_sub3);
 dbms_output.put_line ('Marks of Sub4 : ' || s_sub4);
end;
/




